# ---------------------------------------------------------------------------
# ⚠️ 程序只加载项目根目录下的文件名「.env」，不会读取「.env.example」。
#    请在本目录执行：  copy .env.example .env   （PowerShell / CMD）
#    然后编辑 .env，填写 DEEPSEEK_API_KEY（只改 .env，不要提交到 Git）。
# ---------------------------------------------------------------------------
# pydantic-settings 读取 .env 时使用 UTF-8 编码。

# ========== 大模型（使用分析/优化功能时必填）==========
# DeepSeek API Key（https://platform.deepseek.com ）
# 可留空：服务能启动；调用模型须在 .env 中填写有效密钥。
DEEPSEEK_API_KEY=

# ========== 模型与端点（可选）==========
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# REQUEST_TIMEOUT_SECONDS=120

# ========== 输入与上传限制（可选）==========
# MAX_RESUME_CHARS=120000
# MAX_JD_CHARS=50000
# MAX_UPLOAD_BYTES=2097152

# ========== 限流（单进程内存；可选）==========
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_ENABLED=true

# ========== 分析缓存（单进程；可选）==========
# ENABLE_ANALYSIS_CACHE=true
# ANALYSIS_CACHE_TTL_SECONDS=300

# ========== PDF 导出（可选）==========
# 中文字体路径 .ttf / .ttc；Linux/Docker 通常已含 Noto；Windows 可设为 msyh.ttc
# PDF_FONT_PATH=

# ========== 仅测试 / CI（生产勿设）==========
# TESTING=1
